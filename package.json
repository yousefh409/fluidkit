{
  "name": "fluidkit",
  "version": "0.5.0",
  "description": "Liquid UI animations for React — one metaball engine, swappable glass/flat materials, built on Motion.",
  "keywords": [
    "react",
    "animation",
    "liquid",
    "glass",
    "metaball",
    "fluid",
    "motion",
    "ui",
    "backdrop-filter",
    "spring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yousefh409/fluidkit.git"
  },
  "homepage": "https://github.com/yousefh409/fluidkit#readme",
  "bugs": {
    "url": "https://github.com/yousefh409/fluidkit/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./liquid-metal": {
      "types": "./dist/liquid-metal.d.ts",
      "import": "./dist/liquid-metal.js",
      "require": {
        "types": "./dist/liquid-metal.d.cts",
        "default": "./dist/liquid-metal.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:site": "vite build playground",
    "check:gpu-leak": "node scripts/check-no-gpu-deps.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "dev": "vite playground",
    "size": "npm run build && size-limit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "36.7 kB",
      "brotli": true
    }
  ],
  "peerDependencies": {
    "@paper-design/shaders-react": "0.0.76",
    "motion": ">=11",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@paper-design/shaders-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@paper-design/shaders-react": "0.0.76",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "motion": "^12.41.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
